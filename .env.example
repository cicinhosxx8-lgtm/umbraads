# ============================================================================
# UmbraAds — variáveis de ambiente
# Copie este arquivo para .env.local e preencha. .env.local está no .gitignore
# e NUNCA deve ser commitado.
# ============================================================================

# ---------------------------------------------------------------- Supabase ---
# Project Settings > API no painel do Supabase.

# URL do projeto (pública). Ex.: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon/public key (pública — pode ir para o browser, é limitada por RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (SECRETA — bypassa RLS). SÓ no servidor. NUNCA no client.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------- RapidAPI ------
# Chave da RapidAPI usada pelo provider de Ad Library (FASE 5).
# ⚠️ Use aqui — nunca hardcoded no código. A chave que estava em
# RAPIDAPI-INFORMAÇOES/scripts/test-api.ts deve ser ROTACIONADA no RapidAPI,
# pois circulou em texto plano.
RAPIDAPI_KEY=

# Host da API escolhida no RapidAPI (validação apontou facebook-scraper3).
RAPIDAPI_HOST=facebook-scraper3.p.rapidapi.com

# ------------------------------------------------------------- Crons ---------
# Segredo compartilhado que protege /api/cron/* (Vercel Cron manda no header).
# Gere um valor aleatório forte. Ex.: openssl rand -hex 32
CRON_SECRET=

# -------------------------------------------------------- Kiwify (pagamento) ---
# Secret do webhook (Kiwify → Apps → Webhooks). O MESMO valor vai no painel da
# Kiwify e aqui. O webhook valida HMAC-SHA1 do corpo com esse secret.
KIWIFY_WEBHOOK_SECRET=
# IDs (checkout_link) dos produtos — já têm default no código, override opcional.
KIWIFY_PRODUCT_ID_BASICO=fnJ6e8P
KIWIFY_PRODUCT_ID_PRO=0FTOD9I
KIWIFY_PRODUCT_ID_ELITE=L0PUomP

# ------------------------------------------------------------- App -----------
# URL pública do app (usada em redirects de OAuth, e-mails, etc.).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
